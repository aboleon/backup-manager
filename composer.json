{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "aboleon/backup-manager",
    "description": "Change-aware database backups and incremental media synchronization for Laravel applications",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "ext-zlib": "*",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/events": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0",
        "illuminate/queue": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/view": "^11.0|^12.0|^13.0",
        "spatie/db-dumper": "^3.8",
        "symfony/process": "^7.0|^8.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Aboleon\\BackupManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aboleon\\BackupManager\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aboleon\\BackupManager\\BackupManagerServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
